{
  "kind": "singleType",
  "collectionName": "settings",
  "info": {
    "singularName": "setting",
    "pluralName": "settings",
    "displayName": "Settings"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "companyName": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "maxLength": 11,
      "regex": "^\\d{10,11}$"
    },
    "whatsapp": {
      "type": "string",
      "maxLength": 13,
      "required": true,
      "regex": "^\\d{12,13}$"
    },
    "address": {
      "type": "text"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "defaultSEO": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
